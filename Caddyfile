# ============================================
# AI智能组卷 — Caddy HTTPS 反向代理
# ============================================

{$DOMAIN:localhost} {
    # API 代理到 NestJS 后端
    handle /v1/* {
        reverse_proxy backend:3000
    }

    # 下载文件代理
    handle /download/* {
        reverse_proxy backend:3000
    }

    # 健康检查
    handle /health {
        reverse_proxy backend:3000
    }

    # 前端 SPA（所有其他请求 → frontend Nginx）
    handle {
        reverse_proxy frontend:80
    }

    # 安全头
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
    }

    # Gzip
    encode gzip

    # 日志
    log {
        output stdout
    }
}
