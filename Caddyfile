# ============================================
# Caddy Reverse Proxy — AI智能组卷
# ============================================
# 生产环境: 将 yourdomain.com 替换为真实域名
# 本地开发: 使用 localhost (自签证书)

{$DOMAIN:localhost} {
    # API → NestJS backend
    handle /v1/* {
        reverse_proxy backend:3000
    }

    # Downloads → NestJS backend
    handle /download/* {
        reverse_proxy backend:3000
    }

    # Health check
    handle /health {
        reverse_proxy backend:3000
    }

    # 前端静态文件 (H5 build)
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # Gzip
    encode gzip

    # Logging
    log {
        output file /var/log/caddy/access.log
    }
}
