# ============================================
# AI智能组卷 — 生产环境变量模板
# 复制为 .env 并填入真实值
# ============================================

# ---- Domain ----
DOMAIN=yourdomain.com

# ---- Database ----
DB_PASSWORD=change-me-to-strong-password

# ---- Admin (手机号，逗号分隔；首次用此手机号登录即自动成为管理员) ----
ADMIN_PHONES=13800138000

# ---- JWT ----
JWT_SECRET=change-me-to-random-64-char-string

# ---- AI (阿里百炼) ----
QWEN3_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN3_API_KEY=sk-your-key
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_API_KEY=sk-your-key

# ---- 邮箱验证码 ----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=286851125@qq.com
SMTP_PASS=授权码

# ---- 短信验证码 (阿里云) ----
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=AI智能组卷
SMS_TEMPLATE_CODE=SMS_XXXXXXXX

# ---- 支付宝电脑网站支付 ----
ALIPAY_APP_ID=2021xxxxxxxxxxxx
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n你的应用私钥\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n支付宝公钥\n-----END PUBLIC KEY-----
ALIPAY_NOTIFY_URL=https://yourdomain.com/v1/payment/alipay/callback
ALIPAY_RETURN_URL=https://yourdomain.com/orders

# ---- 微信 (保留兼容，可不填) ----
# WX_APP_ID=
# WX_APP_SECRET=

# ---- 微信支付 (保留兼容，可不填) ----
# WX_MCH_ID=
# WX_API_V3_KEY=
# WX_MCH_SERIAL_NO=
# WX_MCH_PRIVATE_KEY=
# WX_PAY_NOTIFY_URL=

# ---- Tencent COS (File Storage) ----
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-guangzhou
