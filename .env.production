# ============================================
# AI智能组卷 — 生产环境变量模板
# 复制为 .env 并填入真实值
# ============================================

# ---- Domain (for Caddy SSL auto-provision) ----
DOMAIN=yourdomain.com

# ---- Database ----
DB_PASSWORD=change-me-to-strong-password

# ---- Admin (comma-separated WeChat openids for admin accounts) ----
# 把你自己的微信 openid 填到这里，首次登录即自动成为管理员
# 获取方式: 登录一次后在后端日志中查看，或从微信公众平台调试
ADMIN_OPENIDS=

# ---- JWT ----
JWT_SECRET=change-me-to-random-64-char-string

# ---- AI (阿里百炼) ----
QWEN3_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN3_API_KEY=sk-your-key
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_API_KEY=sk-your-key

# ---- WeChat Mini Program ----
WX_APP_ID=wx_your_app_id
WX_APP_SECRET=your_app_secret

# ---- WeChat Pay V3 ----
WX_MCH_ID=your_merchant_id
WX_API_V3_KEY=your_32_char_hex_key
WX_MCH_SERIAL_NO=your_cert_serial_no
WX_MCH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----
WX_PAY_NOTIFY_URL=https://yourdomain.com/v1/orders/callback

# ---- Tencent COS (File Storage) ----
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-guangzhou
