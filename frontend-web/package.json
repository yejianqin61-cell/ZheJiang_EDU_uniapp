    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.10.5",
    "jsdom": "^29.1.1",
    "sass-embedded": "^1.100.0",
